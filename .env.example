# =============================================================================
# DeepEval Lab — environment variables
# Copy to .env and fill in. .env is gitignored.
# =============================================================================

# --- LLM providers ------------------------------------------------------------
# Required for any remote model (chat or judge).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Groq gives free/cheap inference for open-source models
# (used as a fast Ollama-compatible alternative in CI).
GROQ_API_KEY=

# --- Ollama (local models) ----------------------------------------------------
# Default Ollama URL. Install: https://ollama.com  then `ollama serve`.
OLLAMA_BASE_URL=http://localhost:11434

# --- DeepEval / Confident AI --------------------------------------------------
# Optional: push eval runs to https://app.confident-ai.com for the web dashboard.
CONFIDENT_API_KEY=

# --- RAG ----------------------------------------------------------------------
# Where ChromaDB persists its index. Relative to repo root is fine.
CHROMA_PATH=./.chroma
# Embedding provider:
#   chromadb (default) — ONNX all-MiniLM-L6-v2, offline, no key needed
#   ollama             — local model via Ollama (set EMBEDDING_MODEL)
#   openai             — text-embedding-3-small, requires OPENAI_API_KEY
EMBEDDING_PROVIDER=chromadb
# Only used when EMBEDDING_PROVIDER=ollama or openai. Ignored otherwise.
EMBEDDING_MODEL=nomic-embed-text

# --- App ----------------------------------------------------------------------
LOG_LEVEL=INFO
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# --- CI safety knob -----------------------------------------------------------
# Hard cap on number of test cases per suite when running with -m smoke.
SMOKE_MAX_CASES=15
